<UserControl
    x:Class="wisland.Views.ImmersiveMediaView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:wisland.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <Style x:Key="TransportButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="36" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style x:Key="PlayPauseButtonStyle" TargetType="Button">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="Width" Value="40" />
            <Setter Property="Height" Value="40" />
            <Setter Property="CornerRadius" Value="20" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style x:Key="HeaderChipButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="UseSystemFocusVisuals" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid x:Name="RootGrid">
        <!-- Background layer: gradient from album art colors -->
        <Grid x:Name="BackgroundLayer">
            <Border x:Name="GradientBackground" CornerRadius="0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop x:Name="GradientStop0" Color="#FF282832" Offset="0.0" />
                        <GradientStop x:Name="GradientStop1" Color="#FF191923" Offset="0.6" />
                        <GradientStop x:Name="GradientStop2" Color="#FF20202A" Offset="1.0" />
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
            <!-- Album art blurred background (composition visual host) -->
            <Border x:Name="BlurHost"
                    Opacity="0.45"
                    IsHitTestVisible="False" />
            <!-- Dark scrim for text legibility -->
            <Border Background="#80000000" IsHitTestVisible="False" />
        </Grid>

        <!-- Content layer -->
        <Grid Margin="20,10,20,12" RowSpacing="6">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" /> <!-- Header chip -->
                <RowDefinition Height="*" />    <!-- Media content -->
                <RowDefinition Height="Auto" /> <!-- Progress -->
                <RowDefinition Height="Auto" /> <!-- Transport -->
            </Grid.RowDefinitions>

            <!-- Row 0: Header chip with source info -->
            <Grid Grid.Row="0" HorizontalAlignment="Center">
                <Button x:Name="SessionHeaderButton"
                        Style="{StaticResource HeaderChipButtonStyle}"
                        HorizontalAlignment="Center"
                        Click="OnSessionHeader_Click">
                    <Border x:Name="HeaderChipBorder"
                            CornerRadius="10"
                            Padding="8,2,8,2"
                            Background="#30FFFFFF">
                        <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                            <Border x:Name="HeaderIconBorder"
                                    Width="14" Height="14"
                                    CornerRadius="3"
                                    VerticalAlignment="Center">
                                <Image x:Name="HeaderIcon"
                                       Stretch="Uniform" Margin="1" />
                            </Border>
                            <TextBlock x:Name="HeaderLabel"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       MaxWidth="160"
                                       TextTrimming="CharacterEllipsis" />
                            <FontIcon x:Name="HeaderExpandGlyph"
                                      Glyph="&#xE70D;"
                                      FontSize="8"
                                      VerticalAlignment="Center"
                                      Visibility="Collapsed" />
                        </StackPanel>
                    </Border>
                </Button>
            </Grid>

            <!-- Row 1: Album art + metadata side by side -->
            <Grid Grid.Row="1" ColumnSpacing="14" VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Album art with rounded corners and subtle shadow -->
                <Grid Grid.Column="0" Width="80" Height="80">
                    <Border CornerRadius="10"
                            Background="#20FFFFFF">
                        <Border x:Name="AlbumArtBorder" CornerRadius="10">
                            <Grid>
                                <Image x:Name="AlbumArtImage"
                                       Stretch="UniformToFill"
                                       Width="80" Height="80" />
                                <!-- Fallback icon when no album art -->
                                <FontIcon x:Name="AlbumArtFallback"
                                          Glyph="&#xE8D6;"
                                          FontSize="28"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Visibility="Collapsed" />
                            </Grid>
                        </Border>
                    </Border>
                    <!-- Source badge (app icon, bottom-right overlay) -->
                    <Border x:Name="SourceBadge"
                            Width="22" Height="22"
                            CornerRadius="6"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Bottom"
                            Margin="0,0,-4,-4"
                            Padding="2"
                            Background="#CC000000">
                        <Image x:Name="SourceBadgeIcon"
                               Stretch="Uniform" />
                    </Border>
                </Grid>

                <!-- Metadata column -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                    <Grid x:Name="MetadataViewport" Height="48">
                        <Grid x:Name="MetadataSlotPrimary">
                            <StackPanel VerticalAlignment="Center" Spacing="2">
                                <controls:MarqueeText x:Name="TitlePrimary"
                                    MarqueeFontSize="15"
                                    MarqueeFontWeight="SemiBold"
                                    MaxWidth="260"
                                    HorizontalAlignment="Left" />
                                <controls:MarqueeText x:Name="ArtistPrimary"
                                    MarqueeFontSize="12"
                                    MaxWidth="260"
                                    HorizontalAlignment="Left" />
                            </StackPanel>
                        </Grid>
                        <Grid x:Name="MetadataSlotSecondary" Visibility="Collapsed">
                            <StackPanel VerticalAlignment="Center" Spacing="2">
                                <controls:MarqueeText x:Name="TitleSecondary"
                                    MarqueeFontSize="15"
                                    MarqueeFontWeight="SemiBold"
                                    MaxWidth="260"
                                    HorizontalAlignment="Left" />
                                <controls:MarqueeText x:Name="ArtistSecondary"
                                    MarqueeFontSize="12"
                                    MaxWidth="260"
                                    HorizontalAlignment="Left" />
                            </StackPanel>
                        </Grid>
                    </Grid>
                </StackPanel>
            </Grid>

            <!-- Row 2: Progress bar + time labels -->
            <Grid Grid.Row="2" ColumnSpacing="8" Margin="0,2,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="ElapsedTimeText"
                           Grid.Column="0"
                           FontSize="10"
                           VerticalAlignment="Center"
                           Text="0:00" />

                <Grid Grid.Column="1" Height="4" VerticalAlignment="Center" CornerRadius="2">
                    <Border x:Name="ProgressTrack"
                            CornerRadius="2"
                            Background="#40FFFFFF" />
                    <Border x:Name="ProgressFill"
                            CornerRadius="2"
                            HorizontalAlignment="Left"
                            Width="0">
                        <Border.Background>
                            <SolidColorBrush x:Name="ProgressFillBrush" Color="#FFFFFFFF" />
                        </Border.Background>
                    </Border>
                </Grid>

                <TextBlock x:Name="TotalTimeText"
                           Grid.Column="2"
                           FontSize="10"
                           VerticalAlignment="Center"
                           Text="0:00" />
            </Grid>

            <!-- Row 3: Transport controls -->
            <StackPanel Grid.Row="3"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Spacing="20"
                        Margin="0,2,0,0">
                <Button x:Name="BtnBack"
                        Style="{StaticResource TransportButtonStyle}"
                        Click="BtnBack_Click">
                    <FontIcon Glyph="&#xE892;" FontSize="16" />
                </Button>

                <Button x:Name="BtnPlayPause"
                        Style="{StaticResource PlayPauseButtonStyle}"
                        Click="BtnPlayPause_Click">
                    <FontIcon x:Name="PlayPauseIcon" Glyph="&#xE769;" FontSize="18" />
                </Button>

                <Button x:Name="BtnForward"
                        Style="{StaticResource TransportButtonStyle}"
                        Click="BtnForward_Click">
                    <FontIcon Glyph="&#xE893;" FontSize="16" />
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
