<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="wisland.Views.Settings.AiModelsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

        <Grid Background="Transparent">
                <ScrollViewer Background="Transparent"
                                          Padding="32,24,32,24">
                        <StackPanel Spacing="16"
                MaxWidth="600">
                                <TextBlock Text="AI Models"
                    Style="{StaticResource TitleTextBlockStyle}"/>
                                <TextBlock Text="Configure the models used for song metadata cleanup. OpenAI Compatible works with any OpenAI-style endpoint, and Google AI Studio can optionally use Google grounding search when the selected Gemini model supports it."
                       Style="{StaticResource BodyTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       TextWrapping="WrapWholeWords"/>

            <!-- Model list -->
            <ListView x:Name="ModelList"
                    SelectionMode="None"
                      ItemClick="ModelList_ItemClick"
                    IsItemClickEnabled="True">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="4,8"
                                ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0"
                                    VerticalAlignment="Center">
                                <TextBlock Text="{Binding DisplayName}"
                                        FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding Summary}"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        FontSize="12"/>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Content="Edit"
                                    Tag="{Binding Id}"
                                    Click="EditModel_Click"
                                    Padding="8,4"/>
                            <Button Grid.Column="2"
                                    Content="Delete"
                                    Tag="{Binding Id}"
                                    Click="DeleteModel_Click"
                                    Padding="8,4"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <Button x:Name="AddModelButton"
                    Content="Add Model"
                    Click="AddModel_Click"
                    Style="{StaticResource AccentButtonStyle}"/>

            <!-- Add/Edit form -->
            <Border x:Name="FormPanel"
                    Visibility="Collapsed"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="20,16">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="FormTitle"
                            Text="Add Model"
                            Style="{StaticResource SubtitleTextBlockStyle}"/>

                    <ComboBox x:Name="ProviderCombo"
                            Header="Provider"
                            Width="280"
                              SelectionChanged="ProviderCombo_SelectionChanged">
                                <ComboBoxItem Content="OpenAI Compatible"
                                        Tag="OpenAICompatible"/>
                        <ComboBoxItem Content="Google AI Studio"
                                Tag="GoogleAIStudio"/>
                    </ComboBox>

                    <TextBox x:Name="DisplayNameBox"
                            Header="Display Name"
                                    PlaceholderText="e.g. Main metadata model"/>
                    <TextBox x:Name="EndpointBox"
                            Header="Endpoint URL"
                                    PlaceholderText="https://api.openai.com/v1"/>
                    <PasswordBox x:Name="ApiKeyBox"
                            Header="API Key"
                            PlaceholderText="sk-..."/>
                    <TextBox x:Name="ModelIdBox"
                            Header="Model ID"
                                    PlaceholderText="e.g. gpt-4o-mini or gemini-3-flash-preview"/>

                    <ComboBox x:Name="ReasoningEffortCombo"
                            Header="Reasoning Effort (Google AI Studio only)"
                              Visibility="Collapsed"
                            Width="280">
                        <ComboBoxItem Content="Default"
                                Tag=""/>
                        <ComboBoxItem Content="Minimal"
                                Tag="minimal"/>
                        <ComboBoxItem Content="Low"
                                Tag="low"/>
                        <ComboBoxItem Content="Medium"
                                Tag="medium"/>
                        <ComboBoxItem Content="High"
                                Tag="high"/>
                        <ComboBoxItem Content="None (Gemini 2.5 only)"
                                Tag="none"/>
                    </ComboBox>

                    <ToggleSwitch x:Name="GroundingToggle"
                            Header="Enable Google grounding search"
                            OnContent="On"
                            OffContent="Off"
                            Visibility="Collapsed"
                            IsOn="True"/>

                    <TextBlock x:Name="GroundingHintText"
                            Text="Only applies to Google AI Studio models. If enabled, Wisland will request Google grounding search for supported Gemini models and automatically fall back if the compatibility endpoint rejects it."
                            Style="{StaticResource BodyTextBlockStyle}"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            TextWrapping="WrapWholeWords"
                            Visibility="Collapsed"/>

                    <StackPanel Orientation="Horizontal"
                            Spacing="8">
                        <Button x:Name="SaveButton"
                                Content="Save"
                                Click="SaveModel_Click"
                                Style="{StaticResource AccentButtonStyle}"/>
                        <Button Content="Cancel"
                                Click="CancelForm_Click"/>
                    </StackPanel>

                    <InfoBar x:Name="FormError"
                            Severity="Error"
                            IsOpen="False"
                            IsClosable="True"/>
                </StackPanel>
            </Border>
                        </StackPanel>
                </ScrollViewer>
        </Grid>
</UserControl>
