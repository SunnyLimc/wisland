<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="wisland.Views.Settings.AiSongOverridePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

        <Grid Background="Transparent" Padding="0,48,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock x:Uid="AiSongTitle"
                    Style="{StaticResource TitleTextBlockStyle}"
                    Margin="32,12,32,0"/>

                <ScrollViewer Grid.Row="1" Background="Transparent">
                        <StackPanel Spacing="16"
                Margin="32,8,32,32"
                MaxWidth="600"
                HorizontalAlignment="Left">
                                  <TextBlock x:Uid="AiSongDescription"
                       Style="{StaticResource BodyTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       TextWrapping="WrapWholeWords"/>

            <ToggleSwitch x:Uid="AiSongEnableToggle" x:Name="EnableToggle"
                          Toggled="EnableToggle_Toggled"/>

            <ComboBox x:Uid="AiSongModelSelector" x:Name="ModelSelector"
                    Width="320"
                      SelectionChanged="ModelSelector_SelectionChanged"/>

            <TextBlock x:Uid="AiSongNoModelsHint" x:Name="NoModelsHint"
                       Foreground="{ThemeResource SystemFillColorCautionBrush}"
                       Visibility="Collapsed"
                    TextWrapping="WrapWholeWords"/>

            <!-- Localization section -->
            <TextBlock x:Uid="AiSongLocalizationTitle" x:Name="AiSongLocalizationTitleText"
                    Style="{StaticResource SubtitleTextBlockStyle}"
                    Margin="0,16,0,0"/>
            <TextBlock x:Uid="AiSongLocalizationDescription" x:Name="AiSongLocalizationDescriptionText"
                       Style="{StaticResource BodyTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       TextWrapping="WrapWholeWords"/>

            <ComboBox x:Uid="AiSongPreferredLanguage" x:Name="PreferredLanguageSelector"
                      Width="320"
                      SelectionChanged="PreferredLanguageSelector_SelectionChanged"/>

            <!-- Native prompt toggle — shown only when a language with native support is selected -->
            <StackPanel x:Name="NativePromptPanel" Spacing="4" Visibility="Collapsed">
                <ToggleSwitch x:Uid="AiSongPreferNativePrompt" x:Name="PreferNativePromptToggle"
                              Toggled="PreferNativePromptToggle_Toggled"/>
                <TextBlock x:Uid="AiSongNativePromptHint"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                           TextWrapping="WrapWholeWords"
                           Margin="0,-4,0,0"/>
            </StackPanel>

            <!-- Region override — hidden when native prompt is ON -->
            <StackPanel x:Name="RegionOverridePanel" Spacing="4">
                <TextBox x:Uid="AiSongRegionOverride" x:Name="TargetMarketBox"
                         Width="320" HorizontalAlignment="Left"
                         LostFocus="TargetMarketBox_LostFocus"/>
                <TextBlock x:Uid="AiSongRegionOverrideHint"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                           TextWrapping="WrapWholeWords"/>
            </StackPanel>

            <!-- Cache section -->
            <TextBlock x:Uid="AiSongCacheTitle" x:Name="AiSongCacheTitleText"
                    Style="{StaticResource SubtitleTextBlockStyle}"
                    Margin="0,16,0,0"/>
            <TextBlock x:Uid="AiSongCacheDescription" x:Name="AiSongCacheDescriptionText"
                       Style="{StaticResource BodyTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       TextWrapping="WrapWholeWords"/>

            <TextBlock x:Name="CacheCountText"
                    Text=""/>

            <StackPanel Orientation="Horizontal"
                    Spacing="8">
                <Button x:Uid="AiSongClearLast" x:Name="ClearLastButton"
                        Click="ClearLast_Click"/>
                <Button x:Uid="AiSongClearAll" x:Name="ClearAllButton"
                        Click="ClearAll_Click"/>
            </StackPanel>

            <!-- Test section -->
            <TextBlock x:Uid="AiSongTestTitle" x:Name="AiSongTestTitleText"
                    Style="{StaticResource SubtitleTextBlockStyle}"
                    Margin="0,16,0,0"/>
            <TextBlock x:Uid="AiSongTestDescription" x:Name="AiSongTestDescriptionText"
                       Style="{StaticResource BodyTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       TextWrapping="WrapWholeWords"/>

            <TextBox x:Uid="AiSongTestSongTitle" x:Name="TestSongTitleBox"
                     Width="320" HorizontalAlignment="Left"/>
            <TextBox x:Uid="AiSongTestSongArtist" x:Name="TestSongArtistBox"
                     Width="320" HorizontalAlignment="Left"/>
            <TextBox x:Uid="AiSongTestSourceName" x:Name="TestSourceNameBox"
                     Width="320" HorizontalAlignment="Left"/>
            <NumberBox x:Uid="AiSongTestDuration" x:Name="TestDurationBox"
                       Width="160" HorizontalAlignment="Left"
                       Minimum="0" SpinButtonPlacementMode="Compact"
                       SmallChange="1" LargeChange="30"/>

            <Button x:Uid="AiSongTestRun" x:Name="TestRunButton"
                    Click="TestRun_Click"
                    Style="{StaticResource AccentButtonStyle}"/>

            <InfoBar x:Name="TestResultInfoBar"
                     IsOpen="False"
                     IsClosable="True"/>
                        </StackPanel>
                </ScrollViewer>
        </Grid>
</UserControl>
