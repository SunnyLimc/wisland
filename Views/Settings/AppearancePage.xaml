<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="wisland.Views.Settings.AppearancePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

        <Grid Background="Transparent">
                <ScrollViewer Background="Transparent"
                                          Padding="32,24,32,24">
                        <StackPanel Spacing="16"
                MaxWidth="600">
                                <TextBlock x:Uid="AppearanceTitle"
                    Style="{StaticResource TitleTextBlockStyle}"/>
                                <TextBlock x:Uid="AppearanceDescription"
                       Style="{StaticResource BodyTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                                <RadioButtons x:Uid="BackdropStyleHeader" x:Name="BackdropSelector"
                          SelectionChanged="BackdropSelector_SelectionChanged">
                                        <RadioButton x:Uid="BackdropMica"
                        Tag="Mica"/>
                                        <RadioButton x:Uid="BackdropAcrylic"
                        Tag="Acrylic"/>
                                        <RadioButton x:Uid="BackdropNone"
                        Tag="None"/>
                                </RadioButtons>

                                <ComboBox x:Uid="LanguageHeader" x:Name="LanguageSelector"
                    Width="280"
                    SelectionChanged="LanguageSelector_SelectionChanged">
                                    <ComboBoxItem x:Uid="LanguageSystemDefault" Tag=""/>
                                    <ComboBoxItem Content="English" Tag="en-US"/>
                                    <ComboBoxItem Content="日本語" Tag="ja"/>
                                    <ComboBoxItem Content="简体中文" Tag="zh-Hans"/>
                                </ComboBox>

                                <InfoBar x:Name="UnpackagedLanguageHint"
                    Severity="Informational"
                    IsOpen="False"
                    IsClosable="False"/>

                                <InfoBar x:Uid="LanguageRestartHint" x:Name="RestartHint"
                    Severity="Informational"
                    IsOpen="False"
                    IsClosable="True"/>
                        </StackPanel>
                </ScrollViewer>
        </Grid>
</UserControl>
