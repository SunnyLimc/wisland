<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="wisland.Views.Settings.DiagnosticsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

        <Grid Background="Transparent" Padding="0,48,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock x:Uid="DiagnosticsTitle"
                    Style="{StaticResource TitleTextBlockStyle}"
                    Margin="32,12,32,0"/>

                <ScrollViewer Grid.Row="1" Background="Transparent">
                        <StackPanel Spacing="16"
                Margin="32,8,32,32"
                MaxWidth="600"
                HorizontalAlignment="Left">
                                <TextBlock x:Uid="DiagnosticsDescription"
                       Style="{StaticResource BodyTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                                <ComboBox x:Uid="LogLevelHeader" x:Name="LogLevelSelector"
                          SelectionChanged="LogLevelSelector_SelectionChanged">
                                        <ComboBoxItem x:Uid="LogLevelTrace" Tag="Trace"/>
                                        <ComboBoxItem x:Uid="LogLevelDebug" Tag="Debug"/>
                                        <ComboBoxItem x:Uid="LogLevelInfo" Tag="Info"/>
                                        <ComboBoxItem x:Uid="LogLevelWarn" Tag="Warn"/>
                                        <ComboBoxItem x:Uid="LogLevelError" Tag="Error"/>
                                </ComboBox>

                                <TextBlock x:Name="LogLevelStatusText"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Visibility="Collapsed"/>

                                <TextBlock x:Uid="DebugDumpsHeader"
                       Style="{StaticResource SubtitleTextBlockStyle}"
                       Margin="0,16,0,0"/>

                                <TextBlock x:Uid="DebugDumpsDescription"
                       Style="{StaticResource BodyTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button x:Uid="DumpIcons" x:Name="DumpIconsButton"
                        Click="DumpIconsButton_Click"/>
                                    <Button x:Uid="DumpGsmtc" x:Name="DumpGsmtcButton"
                        Click="DumpGsmtcButton_Click"/>
                                </StackPanel>

                                <Button x:Uid="OpenDumpFolder" x:Name="OpenDumpFolderButton"
                    Click="OpenDumpFolderButton_Click"/>

                                <TextBlock x:Name="DumpStatusText"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       TextWrapping="Wrap"
                       Visibility="Collapsed"/>

                                <TextBlock x:Uid="TestToolsHeader"
                       Style="{StaticResource SubtitleTextBlockStyle}"
                       Margin="0,16,0,0"/>

                                <Button x:Uid="TestProgress" x:Name="TestProgressButton"
                    Click="TestProgressButton_Click"/>
                        </StackPanel>
                </ScrollViewer>
        </Grid>
</UserControl>
