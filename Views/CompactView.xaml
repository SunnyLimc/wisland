<UserControl
    x:Class="wisland.Views.CompactView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:wisland.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="RootGrid" Opacity="1">
        <Grid x:Name="TextViewport"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch"
              SizeChanged="TextViewport_SizeChanged">
            <Grid x:Name="CompactTextSlotPrimary">
                <TextBlock x:Name="CompactTextPrimary"
                           Text="Wisland"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="12"
                           TextAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           MaxWidth="160"/>
            </Grid>

            <Grid x:Name="CompactTextSlotSecondary" Visibility="Collapsed">
                <TextBlock x:Name="CompactTextSecondary"
                           Text="Wisland"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="12"
                           TextAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           MaxWidth="160"/>
            </Grid>
        </Grid>

        <Border x:Name="SessionCountBadge"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Margin="0,0,10,0"
                Padding="6,1,6,1"
                CornerRadius="9"
                BorderThickness="1"
                Visibility="Collapsed">
            <TextBlock x:Name="CompactSessionCountText"
                       Text="2/2"
                       FontSize="10"
                       FontWeight="SemiBold"
                       TextAlignment="Center"/>
        </Border>
    </Grid>
</UserControl>
