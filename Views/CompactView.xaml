<UserControl
    x:Class="wisland.Views.CompactView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:wisland.Views"
    xmlns:controls="using:wisland.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="RootGrid" Opacity="1">
        <Grid x:Name="TextViewport"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch"
              SizeChanged="TextViewport_SizeChanged">
            <Grid x:Name="CompactTextSlotPrimary">
                <controls:MarqueeText x:Name="CompactTextPrimary"
                                      Text="Wisland"
                                      MarqueeForeground="White"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      MarqueeFontSize="12"
                                      HorizontalTextAlignment="Center"
                                      MaxWidth="160"
                                      ScrollSpeed="30"/>
            </Grid>

            <Grid x:Name="CompactTextSlotSecondary" Visibility="Collapsed">
                <controls:MarqueeText x:Name="CompactTextSecondary"
                                      Text="Wisland"
                                      MarqueeForeground="White"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      MarqueeFontSize="12"
                                      HorizontalTextAlignment="Center"
                                      MaxWidth="160"
                                      ScrollSpeed="30"/>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
