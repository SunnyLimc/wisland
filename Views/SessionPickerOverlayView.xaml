<UserControl
    x:Class="wisland.Views.SessionPickerOverlayView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:wisland.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="RootGrid"
          Background="Transparent"
          UseLayoutRounding="True"
          SizeChanged="RootGrid_SizeChanged"
          KeyDown="RootGrid_KeyDown">
        <Border x:Name="HostSurface"
                CornerRadius="15"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                IsHitTestVisible="False" />

        <Border x:Name="PanelBorder"
                MinWidth="312"
                Padding="8,0,8,0"
                CornerRadius="15"
                BorderThickness="0"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch">
            <ListView x:Name="SessionList"
                      Background="Transparent"
                      BorderThickness="0"
                      IsItemClickEnabled="True"
                      SelectionMode="Single"
                      HorizontalContentAlignment="Stretch"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                      ItemClick="SessionList_ItemClick"
                      KeyDown="SessionList_KeyDown">
                <ListView.Header>
                    <Border Height="8" Background="Transparent" />
                </ListView.Header>

                <ListView.Footer>
                    <Border Height="8" Background="Transparent" />
                </ListView.Footer>

                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0,0,0,6" />
                        <Setter Property="MinHeight" Value="58" />
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="UseSystemFocusVisuals" Value="False" />
                    </Style>
                </ListView.ItemContainerStyle>

                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{Binding RowBackground}"
                                BorderBrush="{Binding RowBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="16"
                                Padding="12,10,12,10">
                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        Width="28"
                                        Height="28"
                                        CornerRadius="14"
                                        Background="{Binding BadgeBackground}"
                                        BorderBrush="{Binding BadgeBorderBrush}"
                                        BorderThickness="1">
                                    <Grid>
                                        <Image Source="{Binding IconSource}"
                                               Width="18"
                                               Height="18"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Visibility="{Binding IconVisibility}" />
                                        <TextBlock Text="{Binding Monogram}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontSize="11"
                                                   FontWeight="Bold"
                                                   Foreground="{Binding PrimaryForeground}"
                                                   Visibility="{Binding MonogramVisibility}" />
                                    </Grid>
                                </Border>

                                <StackPanel Grid.Column="1"
                                            Spacing="3"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="{Binding SourceName}"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               Foreground="{Binding SecondaryForeground}"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding SecondaryLine}"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="{Binding PrimaryForeground}"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>

                                <Border Grid.Column="2"
                                        VerticalAlignment="Center"
                                        Padding="8,3,8,3"
                                        CornerRadius="10"
                                        Background="{Binding StatusBackground}"
                                        BorderBrush="{Binding StatusBorderBrush}"
                                        BorderThickness="1"
                                        Visibility="{Binding StatusVisibility}">
                                    <TextBlock Text="{Binding StatusText}"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               Foreground="{Binding StatusForeground}" />
                                </Border>

                                <Border Grid.Column="3"
                                        Width="16"
                                        Height="16"
                                        Margin="8,0,0,0"
                                        VerticalAlignment="Center"
                                        Background="Transparent"
                                        Opacity="0"
                                        IsHitTestVisible="False" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Border>
    </Grid>
</UserControl>
