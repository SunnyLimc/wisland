<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="wisland.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:wisland"
    xmlns:controls="using:wisland.Controls"
    xmlns:views="using:wisland.Views"
    Title="Wisland">

    <Grid x:Name="RootGrid" Background="Transparent" UseLayoutRounding="True"
          PointerPressed="RootGrid_PointerPressed"
          PointerMoved="RootGrid_PointerMoved"
          PointerReleased="RootGrid_PointerReleased"
          PointerWheelChanged="RootGrid_PointerWheelChanged"
          PointerEntered="RootGrid_PointerEntered"
          PointerExited="RootGrid_PointerExited">

        <Border x:Name="HostSurface"
                Background="Black"
                CornerRadius="15"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                IsHitTestVisible="False"/>

        <Border x:Name="IslandBorder"
                Background="Black"
                CornerRadius="15"
                Width="200"
                Height="30"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <Border.ContextFlyout>
                <MenuFlyout Opening="IslandContextFlyout_Opening"
                            Closed="IslandContextFlyout_Closed">
                    <MenuFlyoutItem x:Uid="ContextSettings"
                            Click="Settings_Click"/>
                    <MenuFlyoutSeparator/>
                    <MenuFlyoutItem x:Uid="ContextExit" Click="Exit_Click"/>
                </MenuFlyout>
            </Border.ContextFlyout>

            <Grid x:Name="ContentContainer">
                <controls:LiquidProgressBar x:Name="IslandProgressBar" />

                <!-- Compact State Content -->
                <views:CompactView x:Name="CompactContent" Opacity="1" />

                <!-- Expanded State Content (classic) -->
                <views:ExpandedMediaView x:Name="ExpandedContent" Opacity="0" IsHitTestVisible="False"
                                         BackClick="SkipPrevious_Click"
                                         PlayPauseClick="PlayPause_Click"
                                         ForwardClick="SkipNext_Click" />

                <!-- Expanded State Content (immersive) -->
                <views:ImmersiveMediaView x:Name="ImmersiveContent" Opacity="0" IsHitTestVisible="False"
                                          BackClick="SkipPrevious_Click"
                                          PlayPauseClick="PlayPause_Click"
                                          ForwardClick="SkipNext_Click"
                                          SeekRequested="ImmersiveContent_SeekRequested" />
            </Grid>
        </Border>
    </Grid>
</Window>
