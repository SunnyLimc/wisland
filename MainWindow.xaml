<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="island.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:island"
    Title="island">

    <Grid x:Name="RootGrid" Background="Transparent"
          PointerPressed="RootGrid_PointerPressed"
          PointerMoved="RootGrid_PointerMoved"
          PointerReleased="RootGrid_PointerReleased"
          PointerEntered="RootGrid_PointerEntered"
          PointerExited="RootGrid_PointerExited">
        
        <Border x:Name="IslandBorder"
                Width="200" Height="30"
                Background="Black"
                CornerRadius="15"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            
            <Border.ContextFlyout>
                <MenuFlyout>
                    <MenuFlyoutItem Text="Test Notification" Click="TestNotification_Click"/>
                    <MenuFlyoutItem Text="Test Task Progress" Click="TestProgress_Click"/>
                    <MenuFlyoutSeparator/>
                    <MenuFlyoutSubItem Text="Backdrop Style">
                        <MenuFlyoutItem Text="Mica" Click="Mica_Click"/>
                        <MenuFlyoutItem Text="Acrylic" Click="Acrylic_Click"/>
                        <MenuFlyoutItem Text="None" Click="None_Click"/>
                    </MenuFlyoutSubItem>
                    <MenuFlyoutSeparator/>
                    <MenuFlyoutItem Text="Exit" Click="Exit_Click"/>
                </MenuFlyout>
            </Border.ContextFlyout>
            
            <Grid x:Name="ContentContainer">
                <!-- Liquid Glass Progress Layer -->
                <Grid x:Name="LiquidGlassProgressLayer" 
                      Width="0" 
                      HorizontalAlignment="Left">
                    
                    <!-- Layer 1: Ambient frosted base (Subtle overall volume fill) -->
                    <Border Background="#1AFFFFFF" />

                    <!-- Layer 3: The dynamic 'Comet' tail (Directional energy) -->
                    <Border Width="120" HorizontalAlignment="Right">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                <GradientStop Color="#00FFFFFF" Offset="0.0"/>
                                <GradientStop Color="#20FFFFFF" Offset="0.5"/>
                                <GradientStop Color="#70FFFFFF" Offset="0.9"/>
                                <GradientStop Color="#D0FFFFFF" Offset="1.0"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    
                    <!-- Layer 4: The bright leading edge core (Precision laser focus point) -->
                    <!-- We will set its Height and CornerRadius dynamically in C# so it scales gracefully -->
                    <Border x:Name="ProgressLaserCore" Width="2" HorizontalAlignment="Right" Background="#FFFFFFFF" Opacity="0.9"/>
                </Grid>

                <!-- Compact State Content -->
                <Grid x:Name="CompactContent" Opacity="1">
                    <TextBlock x:Name="CompactText" Text="Dynamic Island" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12"/>
                </Grid>

                <!-- Expanded State Content -->
                <Grid x:Name="ExpandedContent" Opacity="0" IsHitTestVisible="False">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock x:Name="HeaderStatusText" Text="Now Playing" Foreground="Gray" FontSize="10" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="MusicTitleText" Text="No Media" Foreground="White" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="ArtistNameText" Text="Artist Name" Foreground="LightGray" FontSize="12" HorizontalAlignment="Center"/>
                        
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0" Spacing="20">
                            <Button x:Name="BtnBack" Background="Transparent" BorderThickness="0" Padding="4" Click="SkipPrevious_Click">
                                <SymbolIcon x:Name="IconBack" Symbol="Back" Foreground="White"/>
                            </Button>
                            <Button x:Name="BtnPlayPause" Background="Transparent" BorderThickness="0" Padding="4" Click="PlayPause_Click">
                                <SymbolIcon x:Name="IconPlayPause" Symbol="Pause" Foreground="White"/>
                            </Button>
                            <Button x:Name="BtnForward" Background="Transparent" BorderThickness="0" Padding="4" Click="SkipNext_Click">
                                <SymbolIcon x:Name="IconForward" Symbol="Forward" Foreground="White"/>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
